{
  "name": "vibe-k-line",
  "displayName": "Vibe K-Line",
  "description": "Turn your vibe coding session into a stock market. Every file is a stock, every edit is a trade.",
  "version": "0.1.0",
  "publisher": "vibe-k-line",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:codeMarket.open"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeMarket.open",
        "title": "Vibe K-Line: Open"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "^1.74.0",
    "typescript": "^5.0.0"
  }
}
